# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.vercel.app

# Database - Neon PostgreSQL
DATABASE_URL=postgresql://username:password@host.neon.tech/database?sslmode=require

# Or individual DB settings
DB_NAME=biomex
DB_USER=biomex_user
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

# RAG / LLM (Hugging Face + Pinecone)
RAG_HF_API_TOKEN=hf_xxx
RAG_HF_GENERATION_MODEL=m42-health/Med42-v2-8B
RAG_HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Optional: use a dedicated HF Inference Endpoint URL for generation
RAG_HF_GENERATION_URL=

RAG_PINECONE_API_KEY=pcsk_xxx
# Example host: your-index-xxxx.svc.aped-4627-b74a.pinecone.io
RAG_PINECONE_INDEX_HOST=
RAG_PINECONE_NAMESPACE=biomex-knowledge
RAG_DEFAULT_TOP_K=6
RAG_MAX_CONTEXT_CHARS=12000
